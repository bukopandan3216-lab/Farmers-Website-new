# Example environment variables for backend
# Copy this to .env and fill values for local development (DO NOT commit .env)

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# SMTP (for sending approval emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_FROM="FarmDirect <noreply@farmdirect.com>"

# Frontend URL used in account creation links
FRONTEND_URL=http://localhost:5173
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
PORT=5000
NODE_ENV=development
CLIENT_URL=https://farmers-website-new.vercel.app
JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-another-long-random-secret
JWT_EXPIRE_IN=15m
JWT_REFRESH_EXPIRE_IN=30d
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
