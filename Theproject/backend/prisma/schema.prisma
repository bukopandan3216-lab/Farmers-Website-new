// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  fullName  String
  passwordHash String
  avatar    String?
  phone     String?
  address   String?
  role      Role     @default(BUYER)
  accountSetupCompleted Boolean @default(false)
  totalSpent Decimal @default(0) @db.Decimal(10, 2)
  memberSince DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  farmerProfile    FarmerProfile?
  products         Product[]
  orders           Order[]
  reviews          Review[]
  sentMessages     Message[] @relation("sender")
  receivedMessages Message[] @relation("receiver")
  cartItems        CartItem[]
  cart             Cart?
  favorites        Favorite[]
  refreshTokens    RefreshToken[]
  registrationTokens RegistrationToken[]
  storeFollows     StoreFollower[] @relation("follower")
  storeReviews     StoreReview[]
  adminCommissions AdminCommission[]

  @@map("users")
}

enum Role {
  BUYER
  FARMER
  ADMIN
}

model FarmerProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  farmName      String
  farmDescription String?
  farmLocation  String
  commissionFrequency CommissionFrequency @default(MONTHLY)
  verified      Boolean  @default(false)
  featured      Boolean  @default(false)
  coverImage    String?
  followerCount Int      @default(0)
  totalOrders   Int      @default(0)
  totalRevenue  Decimal  @default(0) @db.Decimal(12, 2)
  avgRating     Decimal  @default(0) @db.Decimal(3, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  followers     StoreFollower[] @relation("farmer")
  storeReviews  StoreReview[]

  @@map("farmer_profiles")
}

model Category {
  id    String  @id @default(cuid())
  name  String  @unique
  image String?

  // Relations
  products Product[]

  @@map("categories")
}

model Product {
  id        String   @id @default(cuid())
  farmerId  String
  farmer    User     @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  name      String
  description String?
  categoryId String
  category  Category @relation(fields: [categoryId], references: [id])
  price     Decimal  @db.Decimal(10, 2)
  stock     Int
  organic   Boolean  @default(false)
  featured  Boolean  @default(false)
  archived  Boolean  @default(false)
  avgRating Decimal  @default(0) @db.Decimal(3, 2)
  images    String[] // Store image URLs as JSON array
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  orderItems OrderItem[]
  reviews    Review[]
  cartItems  CartItem[]
  favorites  Favorite[]

  @@index([farmerId])
  @@index([categoryId])
  @@map("products")
}

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  items CartItem[]

  @@map("carts")
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@map("cart_items")
}

model Order {
  id              String   @id @default(cuid())
  buyerId         String
  buyer           User     @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  total           Decimal  @db.Decimal(12, 2)
  status          OrderStatus @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  deliveryAddress String
  buyerNotes      String?
  logisticsProvider String?
  logisticsAssignedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  orderItems  OrderItem[]
  trackingHistory OrderTracking[]
  adminCommission AdminCommission?

  @@index([buyerId])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int      // 1-5 stars
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([userId])
  @@map("reviews")
}

model Message {
  id        String   @id @default(cuid())
  senderId  String
  sender    User     @relation("sender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver  User     @relation("receiver", fields: [receiverId], references: [id], onDelete: Cascade)
  content   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@map("messages")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([productId])
  @@map("favorites")
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model StoreFollower {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("follower", fields: [userId], references: [id], onDelete: Cascade)
  farmerId  String
  farmer    FarmerProfile @relation("farmer", fields: [farmerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, farmerId])
  @@index([userId])
  @@index([farmerId])
  @@map("store_followers")
}

model StoreReview {
  id        String   @id @default(cuid())
  farmerId  String
  farmer    FarmerProfile @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int      // 1-5 stars
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([farmerId])
  @@index([userId])
  @@map("store_reviews")
}

model OrderTracking {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  updatedAt DateTime @default(now())
  updatedBy String?  // userId of who updated it
  notes     String?

  @@index([orderId])
  @@map("order_tracking")
}

enum NotificationPreference {
  EMAIL
  PHONE
}

enum CommissionFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

model AdminCommission {
  id                String              @id @default(cuid())
  orderId           String              @unique
  order             Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  farmerId          String
  farmer            User                @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  totalOrderSum     Decimal             @db.Decimal(12, 2)
  commissionRate    Decimal             @default(0.05) @db.Decimal(5, 2)
  commissionFee     Decimal             @db.Decimal(10, 2)
  paymentDeadline   CommissionFrequency
  dueDate           DateTime
  isPaid            Boolean             @default(false)
  paidAt            DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([farmerId])
  @@map("admin_commissions")
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model Application {
  id                   String   @id @default(cuid())
  fullName             String
  email                String   @unique
  hashedPassword       String?
  phone                String
  address              String
  role                 Role
  notificationPreference NotificationPreference @default(EMAIL)
  commissionFrequency  CommissionFrequency?

  farmName             String?
  farmAddress          String?
  description          String?
  photoWithIdUrl       String?
  validIdUrl           String?
  businessPermitUrl    String?
  profileImageUrl      String?

  status               ApplicationStatus @default(PENDING)
  rejectionReason      String?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@map("applications")
}

model RegistrationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("registration_tokens")
}
